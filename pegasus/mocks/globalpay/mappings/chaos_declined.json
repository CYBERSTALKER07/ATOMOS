{
  "priority": 10,
  "request": {
    "method": "POST",
    "urlPathPattern": ".*/payments/v2/payment/init$",
    "bodyPatterns": [
      { "contains": "CHAOS_DECLINE" }
    ]
  },
  "response": {
    "status": 402,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "error": "CARD_DECLINED",
      "message": "The card was declined by the issuing bank.",
      "isSuccessful": false
    }
  }
}
