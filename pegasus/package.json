{
  "name": "pegasus",
  "private": true,
  "scripts": {
    "ast:index": "node ../.agents/extensions/ast-engine/engine.mjs index --root . --index ../.agents/extensions/ast-engine/.cache/pegasus-index.json",
    "ast:def": "node ../.agents/extensions/ast-engine/engine.mjs definition --root . --index ../.agents/extensions/ast-engine/.cache/pegasus-index.json",
    "ast:refs": "node ../.agents/extensions/ast-engine/engine.mjs usages --root . --index ../.agents/extensions/ast-engine/.cache/pegasus-index.json",
    "ast:graph": "node ../.agents/extensions/ast-engine/engine.mjs graph --root . --index ../.agents/extensions/ast-engine/.cache/pegasus-index.json",
    "ast:mcp:start": "node ../.agents/extensions/ast-engine/mcp-server.mjs",
    "localization:validate": "node packages/i18n/scripts/validate.mjs",
    "localization:generate": "node packages/i18n/scripts/generate.mjs",
    "localization:inventory": "node packages/i18n/scripts/inventory.mjs",
    "versionscan:scan": "python3 scripts/versionscan.py scan --repo-root . --output-dir .versionscan",
    "versionscan:enforce": "python3 scripts/versionscan.py enforce --repo-root . --output-dir .versionscan --changed-only",
    "guard:contract": "python3 scripts/contract_drift_guard.py --repo-root ..",
    "guard:architecture": "python3 scripts/architecture_boundary_guard.py --repo-root ..",
    "guard:design-tokens": "python3 scripts/design_token_enforcement_guard.py --repo-root ..",
    "guard:contract-mcp": "python3 scripts/contract_guard_mcp.py --repo-root ..",
    "guard:architecture-mcp": "python3 scripts/architecture_guard_mcp.py --repo-root ..",
    "guard:design-system-mcp": "python3 scripts/design_system_guard_mcp.py --repo-root ..",
    "guard:production-safety": "python3 scripts/production_safety_guard.py --repo-root ..",
    "guard:visual-test-intelligence": "python3 scripts/visual_test_intelligence_guard.py --repo-root ..",
    "guard:security": "python3 scripts/security_guard.py --repo-root ..",
    "guard:one-eye": "python3 scripts/contract_guard_mcp.py --repo-root .. && python3 scripts/architecture_guard_mcp.py --repo-root .. && python3 scripts/design_system_guard_mcp.py --repo-root .. && python3 scripts/production_safety_guard.py --repo-root .. && python3 scripts/visual_test_intelligence_guard.py --repo-root .. && python3 scripts/security_guard.py --repo-root ..",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:admin": "playwright test --project=admin-portal",
    "test:e2e:retailer": "playwright test --project=retailer-desktop",
    "test:e2e:factory": "playwright test --project=factory-portal",
    "test:e2e:warehouse": "playwright test --project=warehouse-portal",
    "test:e2e:api": "playwright test --project=api",
    "test:e2e:cross": "playwright test --project=cross-role",
    "desktop:admin:dev": "npm --prefix apps/admin-portal run tauri:dev",
    "desktop:factory:dev": "npm --prefix apps/factory-portal run tauri:dev",
    "desktop:warehouse:dev": "npm --prefix apps/warehouse-portal run tauri:dev",
    "desktop:retailer:dev": "npm --prefix apps/retailer-app-desktop run tauri:dev",
    "desktop:admin:build:debug": "npm --prefix apps/admin-portal run tauri:build:debug",
    "desktop:factory:build:debug": "npm --prefix apps/factory-portal run tauri:build:debug",
    "desktop:warehouse:build:debug": "npm --prefix apps/warehouse-portal run tauri:build:debug",
    "desktop:retailer:build:debug": "npm --prefix apps/retailer-app-desktop run tauri:build:debug"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
