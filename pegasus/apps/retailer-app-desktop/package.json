{
  "name": "retailer-app-desktop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "next build --turbopack",
    "build:static": "TAURI_BUILD=1 next build",
    "start": "next start --port 3001",
    "lint": "eslint",
    "tauderi": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "TAURI_BUILD=1 tauri build",
    "tauri:build:mac": "TAURI_BUILD=1 tauri build --target universal-apple-darwin",
    "tauri:build:win": "TAURI_BUILD=1 tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:debug": "TAURI_BUILD=1 tauri build --debug",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@pegasus/ui-kit": "file:../../packages/ui-kit",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "lucide-react": "^1.7.0",
    "mapbox-gl": "^3.20.0",
    "maplibre-gl": "^5.19.0",
    "motion": "^12.38.0",
    "next": "15.5.12",
    "qrcode.react": "^4.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-map-gl": "^8.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.1",
    "cypress": "^15.14.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
