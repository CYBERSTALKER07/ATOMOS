# ─── Pegasus — Backend Environment (TEMPLATE) ───────────────────────────────
# Copy to apps/backend-go/.env and fill in real values. Never commit .env.
# The backend panics at boot if any `required` variable is missing or empty.

# ═══════════════════════════════════════════════════════════════════════════════
# RUNTIME (required)
# ═══════════════════════════════════════════════════════════════════════════════
# One of: development | staging | production
# Strictly checked — /debug/mint-token only mounts when ENVIRONMENT=development.
ENVIRONMENT=development

# ═══════════════════════════════════════════════════════════════════════════════
# AUTHENTICATION (required — fail-closed)
# ═══════════════════════════════════════════════════════════════════════════════
# HS256 signing key for legacy JWTs. Generate with:  openssl rand -hex 32
# MUST be rotated across every environment; previously-leaked dev value
# "PEGASUS-VAULT-KEY-2026" is now invalid.
JWT_SECRET=

# Shared secret for service-to-service calls (e.g. AI Worker → Backend via
# X-Internal-Key header). Generate with:  openssl rand -hex 32
INTERNAL_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# VAULT / ENVELOPE ENCRYPTION (required by cmd/seed and vault package)
# ═══════════════════════════════════════════════════════════════════════════════
# 32-byte (64 hex chars) AES-256 master key. Generate with:  openssl rand -hex 32
# Previously-leaked counting key (00..1f) is now invalid — rotate.
VAULT_MASTER_KEY=
# Optional previous-generation key, used during rotation windows.
VAULT_MASTER_KEY_PREV=

# ═══════════════════════════════════════════════════════════════════════════════
# GOOGLE CLOUD SPANNER (required)
# ═══════════════════════════════════════════════════════════════════════════════
SPANNER_PROJECT=pegasus-logistics
SPANNER_INSTANCE=pegasus-dev
SPANNER_DATABASE=pegasus-db
# Leave set for local emulator; unset (or comment out) in production.
SPANNER_EMULATOR_HOST=localhost:9010
# Optional tuning knob (default 16).
SPANNER_HOT_SHARD_COUNT=16

# ═══════════════════════════════════════════════════════════════════════════════
# KAFKA (required)
# ═══════════════════════════════════════════════════════════════════════════════
KAFKA_BROKER_ADDRESS=localhost:9092

# ═══════════════════════════════════════════════════════════════════════════════
# HTTP SERVER (optional — defaults to 8080)
# ═══════════════════════════════════════════════════════════════════════════════
BACKEND_PORT=8080

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS / CACHE (optional)
# ═══════════════════════════════════════════════════════════════════════════════
REDIS_ADDRESS=localhost:6379

# ═══════════════════════════════════════════════════════════════════════════════
# FIREBASE AUTH (optional — enables Firebase ID token verification)
# ═══════════════════════════════════════════════════════════════════════════════
# Path to the service-account JSON file.
FIREBASE_CREDENTIALS_PATH=
# Set when running against the Firebase emulator.
FIREBASE_AUTH_EMULATOR_HOST=
# GCP project ID (needed by Firebase SDK when using the emulator).
GCLOUD_PROJECT=

# ═══════════════════════════════════════════════════════════════════════════════
# GCP SECRET MANAGER (optional — enables managed secret resolution)
# ═══════════════════════════════════════════════════════════════════════════════
GCP_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=

# ═══════════════════════════════════════════════════════════════════════════════
# AI / GEMINI (required for order/ai_preorder.go)
# ═══════════════════════════════════════════════════════════════════════════════
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════════
# MAPS / ROUTING (optional)
# ═══════════════════════════════════════════════════════════════════════════════
GOOGLE_MAPS_API_KEY=
# "lat,lon" — defaults to Tashkent if unset.
DEPOT_LOCATION=41.2995,69.2401

# ═══════════════════════════════════════════════════════════════════════════════
# SUPPLIER COCKPIT STORAGE (optional)
# ═══════════════════════════════════════════════════════════════════════════════
GCS_BUCKET_NAME=

# ═══════════════════════════════════════════════════════════════════════════════
# PAYMENT GATEWAYS (required only for tenants wired to that gateway)
# ═══════════════════════════════════════════════════════════════════════════════
# ── Payme (Paycom) ──
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_MERCHANT_KEY=
PAYME_API_URL=https://checkout.paycom.uz/api
PAYME_CHECKOUT_URL=https://checkout.paycom.uz

# ── Click ──
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_API_URL=https://api.click.uz/v2/merchant
CLICK_CHECKOUT_URL=https://my.click.uz/services/pay

# ── Global Pay ──
GLOBAL_PAY_MERCHANT_ID=
GLOBAL_PAY_USERNAME=
GLOBAL_PAY_PASSWORD=
GLOBAL_PAY_SECRET_KEY=
GLOBAL_PAY_SERVICE_ID=
GLOBAL_PAY_PLATFORM_MERCHANT_ID=
GLOBAL_PAY_GATEWAY_BASE_URL=
GLOBAL_PAY_AUTH_URL=
GLOBAL_PAY_CHECKOUT_CREATE_URL=
GLOBAL_PAY_STATUS_URL=
GLOBAL_PAY_STATUS_METHOD=POST
GLOBAL_PAY_ACCESS_TOKEN_SCHEME=Bearer
GLOBAL_PAY_CHECKOUT_URL=
GLOBAL_PAY_CALLBACK_URL=
GLOBAL_PAY_SUCCESS_REDIRECT_URL=
GLOBAL_PAY_FAIL_REDIRECT_URL=

# ── Hosted checkout redirect base (Stripe and other browser handoff flows) ──
# Pegasus primary domain. If unset, backend defaults to https://app.pegasus.uz.
APP_BASE_URL=
# Legacy bridge key kept for additive compatibility during hostname migration.
APP_BASE_URL_LEGACY=
