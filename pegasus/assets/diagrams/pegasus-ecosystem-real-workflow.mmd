%%{init: {'theme':'base','flowchart': {'nodeSpacing': 42, 'rankSpacing': 92, 'curve': 'linear', 'htmlLabels': true}}}%%
flowchart LR
    classDef role fill:#f8fafc,stroke:#334155,color:#0f172a,stroke-width:1.4px;
    classDef system fill:#dbeafe,stroke:#1d4ed8,color:#0f172a,stroke-width:1.3px;
    classDef realtime fill:#fee2e2,stroke:#dc2626,color:#0f172a,stroke-width:1.3px;
    classDef outcome fill:#dcfce7,stroke:#15803d,color:#0f172a,stroke-width:1.3px;
    classDef warning fill:#ffedd5,stroke:#ea580c,color:#0f172a,stroke-width:1.3px;

    START([Demand and fulfillment<br/>loop starts]):::outcome

    subgraph PHASE1[Demand and Planning]
        direction TB
        S1[Supplier / Admin<br/>configure pricing, catalog,<br/>zones, factories, warehouses]:::role
        R1[Retailer<br/>browse suppliers,<br/>build cart, place order]:::role
        W1[Warehouse Admin<br/>watch stock and forecast,<br/>raise supply request]:::role
        S1 --> R1 --> W1
    end

    subgraph PHASE2[Fulfillment Execution]
        direction TB
        F1[Factory Admin<br/>accept request, produce,<br/>plan transfer and manifest]:::role
        P1[Payload / Payloader<br/>load truck, inject changes,<br/>seal or flag manifest]:::role
        D1[Driver<br/>receive route, drive stops,<br/>offload and verify payment]:::role
        R2[Retailer<br/>receive goods,<br/>confirm payment]:::role
        F1 --> P1 --> D1 --> R2
    end

    subgraph PHASE3[Control and Feedback]
        direction TB
        B1[Platform Backbone<br/>APIs, Spanner, Redis,<br/>Kafka, AI, notifications]:::system
        B2[Realtime Hubs<br/>retailer, driver, payload,<br/>warehouse, fleet]:::realtime
        S2[Supplier / Admin<br/>review dashboard, CRM,<br/>analytics, finance]:::role
        W2[Warehouse Admin<br/>receive transfer or record<br/>shortage and exceptions]:::role
        B1 --> B2 --> S2 --> W2
    end

    subgraph EXCEPTIONS[High-Risk Branches]
        direction TB
        EX1{{Stockout or<br/>forecast breach}}:::warning
        EX2{{Manifest mismatch<br/>or loading exception}}:::warning
        EX3{{Payment issue or<br/>shop-closed stop}}:::warning
        S3[Supplier / Admin<br/>approve overrides, returns,<br/>manual resolution]:::role
    end

    START --> S1
    W1 -->|request submitted| F1
    R2 --> END([Loop closes:<br/>analytics, CRM,<br/>replenishment, next order]):::outcome

    R1 -->|order demand| B1
    W1 -->|warehouse depletion| B1
    P1 -->|sealed manifest| B1
    D1 -->|delivery and payment state| B1
    R2 -->|demand signal and payment feedback| B1

    S2 --> W1
    S2 --> S1
    B2 --> R2
    B2 --> W2

    W1 --> EX1 --> S3
    P1 --> EX2 --> S3
    D1 --> EX3 --> S3
    S3 --> W2
    S3 --> S1
    S3 --> B1