%%{init: {'theme':'base','flowchart': {'nodeSpacing': 40, 'rankSpacing': 64, 'curve': 'linear', 'htmlLabels': true}}}%%
flowchart LR
    classDef role fill:#f8fafc,stroke:#334155,color:#0f172a,stroke-width:1.4px;
    classDef system fill:#dbeafe,stroke:#1d4ed8,color:#0f172a,stroke-width:1.3px;
    classDef realtime fill:#fee2e2,stroke:#dc2626,color:#0f172a,stroke-width:1.3px;
    classDef outcome fill:#dcfce7,stroke:#15803d,color:#0f172a,stroke-width:1.3px;
    classDef warning fill:#ffedd5,stroke:#ea580c,color:#0f172a,stroke-width:1.3px;

    START([Demand and fulfillment<br/>loop starts]):::outcome

    PH1[Demand and Planning<br/>Supplier / Admin configures pricing, catalog, zones, factories, warehouses<br/>Retailer browses suppliers, builds cart, and places order<br/>Warehouse Admin watches stock and raises supply request]:::role

    PH2[Fulfillment Execution<br/>Factory Admin accepts request, produces stock, and plans transfer<br/>Payload / Payloader loads truck, injects changes, seals or flags manifest<br/>Driver executes route and Retailer confirms goods and payment]:::role

    CORE[Platform Backbone<br/>APIs, Spanner, Redis, Kafka, AI, notifications keep the flow consistent]:::system

    LIVE[Realtime Hubs<br/>retailer, driver, payload, warehouse, fleet updates stay live across surfaces]:::realtime

    OPS[Control and Feedback<br/>Supplier / Admin reviews dashboard, CRM, analytics, finance<br/>Warehouse Admin receives transfer or records shortage and exceptions]:::role

    EX[Exception Paths<br/>Stockout or forecast breach<br/>Manifest mismatch or loading exception<br/>Payment issue or shop-closed stop<br/>Supplier / Admin applies overrides, returns, and manual resolution]:::warning

    END([Loop closes:<br/>analytics, replenishment,<br/>next order cycle]):::outcome

    subgraph COL1[ ]
        direction TB
        START --> PH1 --> PH2 --> EX
    end

    subgraph COL2[ ]
        direction TB
        CORE --> LIVE --> OPS --> END
    end

    EX --> OPS
    EX --> OPS
    OPS -->|replenishment and demand loop| PH1
    PH2 -->|sealed manifest, delivery, payment state| CORE
    PH1 -->|order demand and warehouse depletion| CORE
    LIVE -->|field updates| PH2