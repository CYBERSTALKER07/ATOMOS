{
  "batch": "Batch 02D - Remaining Backend Domains and Cross-Role Expansion",
  "algorithms": [
    {
      "name": "h3_cross_node_dispatch_assignment",
      "nodes": [
        "warehouse_demand_signal",
        "factory_supply_candidates",
        "h3_ring_expansion",
        "binpack_manifest_split",
        "home_node_assignment",
        "domain_persist",
        "outbox_emit",
        "cross_role_fanout"
      ],
      "transitions": [
        "warehouse_demand_signal->factory_supply_candidates",
        "factory_supply_candidates->h3_ring_expansion",
        "h3_ring_expansion->binpack_manifest_split",
        "binpack_manifest_split->home_node_assignment",
        "home_node_assignment->domain_persist",
        "domain_persist->outbox_emit",
        "outbox_emit->cross_role_fanout"
      ],
      "guard_conditions": [
        "home_node_scope_enforced_for_driver_and_vehicle",
        "aggregate_partition_key_preserves_event_ordering"
      ],
      "recovery_paths": [
        "if_capacity_mismatch_re_split_manifest",
        "if_fanout_partial_keep_local_delivery_and_retry_peer_publish"
      ]
    },
    {
      "name": "freeze_lock_cross_role_override",
      "nodes": [
        "manual_mutation_request",
        "freeze_lock_acquire",
        "lock_emit",
        "ai_pause",
        "role_scoped_adjustment",
        "freeze_lock_release",
        "ai_resume"
      ],
      "transitions": [
        "manual_mutation_request->freeze_lock_acquire",
        "freeze_lock_acquire->lock_emit",
        "lock_emit->ai_pause",
        "ai_pause->role_scoped_adjustment",
        "role_scoped_adjustment->freeze_lock_release",
        "freeze_lock_release->ai_resume"
      ],
      "guard_conditions": [
        "lock_ttl_prevents_permanent_freeze",
        "only_scoped_roles_can_mutate_target_entities"
      ],
      "recovery_paths": [
        "if_release_missing_auto_expire_lock",
        "if_conflicting_mutation_return_state_conflict"
      ]
    },
    {
      "name": "idempotent_rwtxn_outbox_cross_role",
      "nodes": [
        "api_mutation_call",
        "claims_scope_resolution",
        "idempotency_check",
        "rwtxn_begin",
        "version_and_scope_validation",
        "domain_write",
        "outbox_write",
        "commit",
        "cache_invalidate",
        "relay_broadcast"
      ],
      "transitions": [
        "api_mutation_call->claims_scope_resolution",
        "claims_scope_resolution->idempotency_check",
        "idempotency_check->rwtxn_begin",
        "rwtxn_begin->version_and_scope_validation",
        "version_and_scope_validation->domain_write",
        "domain_write->outbox_write",
        "outbox_write->commit",
        "commit->cache_invalidate",
        "cache_invalidate->relay_broadcast"
      ],
      "guard_conditions": [
        "request_body_scope_fields_never_trusted",
        "outbox_and_domain_rows_written_atomically",
        "idempotency_replay_returns_original_response"
      ],
      "recovery_paths": [
        "if_txn_abort_retry_with_backoff",
        "if_cache_invalidate_fails_log_and_continue"
      ]
    },
    {
      "name": "predictive_replenishment_cross_role",
      "nodes": [
        "history_ingest",
        "feature_windowing",
        "forecast_inference",
        "lookahead_pull_matrix",
        "capacity_policy_gate",
        "recommendation_surface",
        "operator_decision",
        "workflow_trigger"
      ],
      "transitions": [
        "history_ingest->feature_windowing",
        "feature_windowing->forecast_inference",
        "forecast_inference->lookahead_pull_matrix",
        "lookahead_pull_matrix->capacity_policy_gate",
        "capacity_policy_gate->recommendation_surface",
        "recommendation_surface->operator_decision",
        "operator_decision->workflow_trigger"
      ],
      "guard_conditions": [
        "recommendations_are_non_binding_until_accepted",
        "node_scope_and_capacity_checks_before_trigger"
      ],
      "recovery_paths": [
        "if_model_unavailable_fallback_to_threshold_rules",
        "if_operator_rejects_archive_recommendation"
      ]
    }
  ]
}
