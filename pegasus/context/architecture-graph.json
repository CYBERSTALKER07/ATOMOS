{
  "version": "2026-05-03",
  "description": "Canonical machine-readable topology for runtime systems and agent context tooling.",
  "agentContext": {
    "syncSet": [
      "../.github/ACT.md",
      "../.github/copilot-instructions.md",
      "../.github/gemini-instructions.md",
      "architecture.md",
      "architecture-graph.json",
      "technology-inventory.md",
      "technology-inventory.json"
    ],
    "actProtocol": {
      "path": "../.github/ACT.md",
      "alwaysOn": true,
      "enforcedChecks": [
        "spanner",
        "kafka",
        "redis",
        "terraform",
        "maglev",
        "hyperscale_10m"
      ]
    },
    "mcpServer": {
      "path": "../.vscode/mcp.json",
      "template": "../.github/mcp.vscode.example.json",
      "serverId": "void-ast-engine",
      "toolNames": [
        "void_ast_index",
        "void_ast_definition",
        "void_ast_usages",
        "void_ast_graph"
      ]
    },
    "engine": {
      "name": "Local AST Symbol Graph Engine",
      "entry": "../.agents/extensions/ast-engine/engine.mjs",
      "commands": [
        "npm --prefix pegasus run ast:index",
        "npm --prefix pegasus run ast:def -- --symbol <TargetSymbol>",
        "npm --prefix pegasus run ast:refs -- --symbol <TargetSymbol> --limit 50",
        "npm --prefix pegasus run ast:graph -- --symbol <TargetSymbol> --limit 50"
      ],
      "requiredFor": [
        "symbol definition retrieval",
        "usage blast-radius analysis",
        "import-neighbor graph checks"
      ]
    },
    "technologyInventory": {
      "markdown": "technology-inventory.md",
      "json": "technology-inventory.json"
    },
    "sourceOfTruthPolicy": {
      "mode": "codebase_first_dual_read",
      "primary": "runtime_code",
      "secondary": "architecture_docs",
      "syncOnDrift": true,
      "enforcedBy": [
        "pegasus/scripts/contract_guard_mcp.py",
        "pegasus/scripts/architecture_guard_mcp.py",
        "pegasus/scripts/design_system_guard_mcp.py"
      ]
    },
    "oneEyeGuards": {
      "workflow": ".github/workflows/one-eye-guards.yml",
      "scripts": [
        "pegasus/scripts/contract_guard_mcp.py",
        "pegasus/scripts/architecture_guard_mcp.py",
        "pegasus/scripts/design_system_guard_mcp.py",
        "pegasus/scripts/production_safety_guard.py",
        "pegasus/scripts/visual_test_intelligence_guard.py",
        "pegasus/scripts/security_guard.py"
      ],
      "checks": [
        "contract_guard_mcp",
        "architecture_guard_mcp",
        "design_system_guard_mcp",
        "production_safety",
        "visual_test_intelligence",
        "security"
      ]
    }
  },
  "nodes": [
    { "id": "maglev", "type": "infra", "label": "Maglev Reverse Proxy" },
    { "id": "router", "type": "backend", "label": "Chi Router" },
    { "id": "spanner", "type": "data", "label": "Cloud Spanner" },
    { "id": "redis", "type": "data", "label": "Redis Cache + Pub/Sub" },
    { "id": "kafka", "type": "event", "label": "Managed Kafka" },
    { "id": "handlers", "type": "backend", "label": "Domain Handlers" },
    { "id": "ws_hubs", "type": "backend", "label": "WebSocket Hubs" },
    { "id": "outbox_relay", "type": "backend", "label": "Outbox Relay" },
    { "id": "admin_portal", "type": "web", "label": "Admin Portal" },
    { "id": "factory_portal", "type": "web", "label": "Factory Portal" },
    { "id": "warehouse_portal", "type": "web", "label": "Warehouse Portal" },
    { "id": "android_clients", "type": "mobile", "label": "Android Clients" },
    { "id": "ios_clients", "type": "mobile", "label": "iOS Clients" },
    { "id": "payload_terminal", "type": "terminal", "label": "Payload Terminal" },
    { "id": "ai_worker", "type": "worker", "label": "AI Worker" },
    { "id": "reconciler", "type": "worker", "label": "Financial Reconciler" },
    { "id": "copilot_agent", "type": "agent", "label": "GitHub Copilot Agent" },
    { "id": "gemini_agent", "type": "agent", "label": "Gemini Agent" },
    { "id": "act_protocol", "type": "agent_policy", "label": "ACT Companion Protocol" },
    { "id": "ast_mcp_server", "type": "agent_tool", "label": "AST MCP Server" },
    { "id": "ast_engine", "type": "agent_tool", "label": "AST Symbol Graph Engine" },
    { "id": "arch_docs", "type": "docs", "label": "Architecture Docs + Graph" },
    { "id": "tech_inventory", "type": "docs", "label": "Technology Inventory" },
    { "id": "one_eye_guards", "type": "policy_guard", "label": "One-Eye Guard Suite" }
  ],
  "edges": [
    { "from": "admin_portal", "to": "maglev", "relationship": "calls" },
    { "from": "factory_portal", "to": "maglev", "relationship": "calls" },
    { "from": "warehouse_portal", "to": "maglev", "relationship": "calls" },
    { "from": "android_clients", "to": "maglev", "relationship": "calls" },
    { "from": "ios_clients", "to": "maglev", "relationship": "calls" },
    { "from": "payload_terminal", "to": "maglev", "relationship": "calls" },
    { "from": "maglev", "to": "router", "relationship": "routes_to" },
    { "from": "maglev", "to": "ws_hubs", "relationship": "upgrades_to_ws" },
    { "from": "router", "to": "handlers", "relationship": "dispatches" },
    { "from": "handlers", "to": "spanner", "relationship": "rwtxn_outbox_emit" },
    { "from": "handlers", "to": "redis", "relationship": "cache_invalidate" },
    { "from": "ws_hubs", "to": "redis", "relationship": "pubsub_fanout" },
    { "from": "spanner", "to": "outbox_relay", "relationship": "tailed_by" },
    { "from": "outbox_relay", "to": "kafka", "relationship": "publishes" },
    { "from": "kafka", "to": "ai_worker", "relationship": "consumed_by" },
    { "from": "kafka", "to": "reconciler", "relationship": "consumed_by" },
    { "from": "copilot_agent", "to": "act_protocol", "relationship": "follows" },
    { "from": "gemini_agent", "to": "act_protocol", "relationship": "follows" },
    { "from": "act_protocol", "to": "ast_mcp_server", "relationship": "requires" },
    { "from": "act_protocol", "to": "ast_engine", "relationship": "fallback_requires" },
    { "from": "act_protocol", "to": "handlers", "relationship": "codebase_primary" },
    { "from": "act_protocol", "to": "arch_docs", "relationship": "requires" },
    { "from": "act_protocol", "to": "tech_inventory", "relationship": "requires" },
    { "from": "act_protocol", "to": "one_eye_guards", "relationship": "requires" },
    { "from": "copilot_agent", "to": "ast_mcp_server", "relationship": "queries" },
    { "from": "gemini_agent", "to": "ast_mcp_server", "relationship": "queries" },
    { "from": "ast_mcp_server", "to": "ast_engine", "relationship": "executes" },
    { "from": "copilot_agent", "to": "arch_docs", "relationship": "reads" },
    { "from": "gemini_agent", "to": "arch_docs", "relationship": "reads" },
    { "from": "copilot_agent", "to": "tech_inventory", "relationship": "reads" },
    { "from": "gemini_agent", "to": "tech_inventory", "relationship": "reads" },
    { "from": "arch_docs", "to": "ast_engine", "relationship": "sync_contract" }
  ],
  "runtimeContracts": [
    {
      "id": "legacy_order_detail_surface",
      "path": "/v1/orders/{id}",
      "owner": "pegasus/apps/backend-go/order/legacy_orders.go",
      "delegatedFrom": "pegasus/apps/backend-go/main.go",
      "methods": [
        "GET /v1/orders/{id}",
        "GET /v1/orders/{id}/events",
        "PATCH /v1/orders/{id}/status",
        "PATCH /v1/orders/{id}/state"
      ],
      "consumers": [
        "pegasus/apps/driverappios/driverappios/Services/APIClient.swift#getOrder",
        "pegasus/apps/driver-app-android/app/src/main/java/com/pegasus/driver/data/remote/DriverApi.kt#getOrder",
        "pegasus/apps/retailer-app-desktop/app/(dashboard)/orders/page.tsx selected-order fetch",
        "pegasus/apps/admin-portal/app/supplier/orders/page.tsx order detail drawer timeline fetch"
      ],
      "notes": [
        "GET returns an additive superset order-detail payload with line items.",
        "GET /v1/orders/{id}/events returns the scoped OrderEvents audit timeline for the same compatibility surface.",
        "PATCH accepts both /status and /state path aliases.",
        "PATCH accepts either status or state in the request body for legacy compatibility."
      ]
    },
    {
      "id": "supplier_geo_planning_surface",
      "path": "/v1/supplier/{serving-warehouse,geo-report,zone-preview,warehouses/validate-coverage,warehouse-loads}",
      "owner": "pegasus/apps/backend-go/proximityroutes/routes.go",
      "delegatedFrom": "pegasus/apps/backend-go/main.go",
      "methods": [
        "GET /v1/supplier/serving-warehouse",
        "GET /v1/supplier/geo-report",
        "GET /v1/supplier/zone-preview",
        "POST /v1/supplier/warehouses/validate-coverage",
        "GET /v1/supplier/warehouse-loads"
      ],
      "consumers": [
        "pegasus/apps/admin-portal/app/supplier/geo-report/page.tsx",
        "pegasus/apps/admin-portal/app/supplier/warehouses/CoverageEditor.tsx",
        "pegasus/apps/admin-portal/components/warehouse/CoverageMap.tsx"
      ],
      "notes": [
        "Route composition moved out of main.go into proximityroutes without changing the delegated proximity handlers.",
        "Portal consumers currently depend on geo-report, zone-preview, and validate-coverage while serving-warehouse and warehouse-loads remain supplier-facing backend planning support paths."
      ]
    },
    {
        "id": "warehouse_ops_compatibility_surface",
        "path": "/v1/warehouse/ops/*",
        "owner": "pegasus/apps/backend-go/warehouseroutes/routes.go",
        "methods": [
          "GET /v1/warehouse/ops/inventory",
          "PATCH /v1/warehouse/ops/inventory",
          "GET /v1/warehouse/ops/staff",
          "POST /v1/warehouse/ops/staff",
          "GET /v1/warehouse/ops/drivers",
          "POST /v1/warehouse/ops/drivers",
          "PATCH /v1/warehouse/ops/drivers/{id}/assign-vehicle",
          "GET /v1/warehouse/ops/vehicles",
          "POST /v1/warehouse/ops/vehicles",
          "PATCH /v1/warehouse/ops/vehicles/{id}",
          "GET /v1/warehouse/ops/vehicles/{id}"
        ],
        "consumers": [
          "pegasus/apps/warehouse-portal/app/inventory/page.tsx",
          "pegasus/apps/warehouse-portal/app/staff/page.tsx",
          "pegasus/apps/warehouse-portal/app/drivers/page.tsx",
          "pegasus/apps/warehouse-portal/app/vehicles/page.tsx",
          "pegasus/apps/warehouse-app-ios/WarehouseApp/Services/WarehouseService.swift",
          "pegasus/apps/warehouse-app-android/app/src/main/java/com/pegasus/warehouse/data/remote/WarehouseApi.kt"
        ],
        "notes": [
          "Inventory compatibility accepts q and search filters and accepts sku_id or product_id on mutations.",
          "Inventory responses expose both inventory and items collections plus sku_id and product_id aliases.",
          "Staff create accepts an optional pin and returns the effective one-time pin for native client parity.",
          "Vehicle responses expose both max_volume_vu and capacity_vu plus a derived availability status.",
          "Warehouse fleet controls now share driver assign/reset and vehicle activate/deactivate mutations across portal, iOS, and Android.",
          "Warehouse dispatch preview excludes inactive vehicles from the available-driver list so vehicle availability mutations affect dispatch eligibility immediately."
        ]
      },
      {
        "id": "warehouse_live_ws_surface",
        "path": "/ws/warehouse",
        "owner": "pegasus/apps/backend-go/ws/warehouse_hub.go",
        "methods": [
          "WS /ws/warehouse"
        ],
        "consumers": [
          "pegasus/apps/warehouse-portal/app/supply-requests/page.tsx",
          "pegasus/apps/warehouse-portal/app/supply-requests/[id]/page.tsx",
          "pegasus/apps/warehouse-portal/app/dispatch-locks/page.tsx",
          "pegasus/apps/warehouse-app-ios/WarehouseApp/Views/Dispatch/DispatchView.swift",
          "pegasus/apps/warehouse-app-android/app/src/main/java/com/pegasus/warehouse/ui/screens/dispatch/DispatchScreen.kt"
        ],
        "notes": [
          "BroadcastSupplyRequestUpdate is defined in apps/backend-go/ws/warehouse_hub.go and called from apps/backend-go/warehouse/supply_requests.go after create and transition commits.",
          "BroadcastDispatchLockChange is defined in apps/backend-go/ws/warehouse_hub.go and called from apps/backend-go/warehouse/dispatch_lock.go after acquire and release commits.",
          "Portal and native warehouse clients subscribe to SUPPLY_REQUEST_UPDATE and DISPATCH_LOCK_CHANGE with warehouse-scoped filtering.",
          "Portal, iOS, and Android clients auto-reconnect and expose reconnecting/offline live state instead of silently freezing."
        ]
      },
      {
        "id": "warehouse_dispatch_mutation_surface",
        "path": "/v1/warehouse/supply-requests + /v1/warehouse/dispatch-lock*",
        "owner": "pegasus/apps/backend-go/warehouse/supply_requests.go + pegasus/apps/backend-go/warehouse/dispatch_lock.go",
        "methods": [
          "POST /v1/warehouse/supply-requests",
          "PATCH /v1/warehouse/supply-requests/{id}",
          "GET /v1/warehouse/dispatch-locks",
          "POST /v1/warehouse/dispatch-lock",
          "DELETE /v1/warehouse/dispatch-lock?lock_id={id}"
        ],
        "consumers": [
          "pegasus/apps/warehouse-portal/app/supply-requests/[id]/page.tsx",
          "pegasus/apps/warehouse-portal/app/dispatch-locks/page.tsx",
          "pegasus/apps/warehouse-app-ios/WarehouseApp/Views/Dispatch/DispatchView.swift",
          "pegasus/apps/warehouse-app-android/app/src/main/java/com/pegasus/warehouse/ui/screens/dispatch/DispatchScreen.kt"
        ],
        "notes": [
          "Warehouse mobile dispatch surfaces create demand-forecast-backed supply requests and cancel warehouse-owned requests through apps/warehouse-app-ios/WarehouseApp/Services/WarehouseService.swift and apps/warehouse-app-android/app/src/main/java/com/pegasus/warehouse/data/remote/WarehouseApi.kt.",
          "Warehouse portal and native clients acquire and release MANUAL_DISPATCH locks against the same dispatch-lock contract.",
          "Dispatch control parity now spans portal, iOS, and Android warehouse clients."
        ]
    }
  ]
}
