    { "id": "copilot_agent", "type": "agent", "label": "GitHub Copilot Agent" },
    { "id": "gemini_agent", "type": "agent", "label": "Gemini Agent" },
    { "id": "act_protocol", "type": "agent_policy", "label": "ACT Companion Protocol" },
    { "id": "ast_mcp_server", "type": "agent_tool", "label": "AST MCP Server" },
    { "id": "ast_engine", "type": "agent_tool", "label": "AST Symbol Graph Engine" },
    { "id": "arch_docs", "type": "docs", "label": "Architecture Docs + Graph" },
    { "id": "tech_inventory", "type": "docs", "label": "Technology Inventory" },
    { "id": "one_eye_guards", "type": "policy_guard", "label": "One-Eye Guard Suite" }
  ],
  "edges": [
    { "from": "admin_portal", "to": "maglev", "relationship": "calls" },
    { "from": "factory_portal", "to": "maglev", "relationship": "calls" },
    { "from": "warehouse_portal", "to": "maglev", "relationship": "calls" },
    { "from": "android_clients", "to": "maglev", "relationship": "calls" },
    { "from": "ios_clients", "to": "maglev", "relationship": "calls" },
    { "from": "payload_terminal", "to": "maglev", "relationship": "calls" },
    { "from": "maglev", "to": "router", "relationship": "routes_to" },
    { "from": "maglev", "to": "ws_hubs", "relationship": "upgrades_to_ws" },
    { "from": "router", "to": "handlers", "relationship": "dispatches" },
    { "from": "handlers", "to": "spanner", "relationship": "rwtxn_outbox_emit" },
    { "from": "handlers", "to": "redis", "relationship": "cache_invalidate" },
    { "from": "ws_hubs", "to": "redis", "relationship": "pubsub_fanout" },
    { "from": "spanner", "to": "outbox_relay", "relationship": "tailed_by" },
    { "from": "outbox_relay", "to": "kafka", "relationship": "publishes" },
    { "from": "kafka", "to": "ai_worker", "relationship": "consumed_by" },
    { "from": "kafka", "to": "reconciler", "relationship": "consumed_by" },
    { "from": "copilot_agent", "to": "act_protocol", "relationship": "follows" },
    { "from": "gemini_agent", "to": "act_protocol", "relationship": "follows" },
    { "from": "act_protocol", "to": "ast_mcp_server", "relationship": "requires" },
    { "from": "act_protocol", "to": "ast_engine", "relationship": "fallback_requires" },
    { "from": "act_protocol", "to": "handlers", "relationship": "codebase_primary" },
    { "from": "act_protocol", "to": "arch_docs", "relationship": "requires" },
    { "from": "act_protocol", "to": "tech_inventory", "relationship": "requires" },
    { "from": "act_protocol", "to": "one_eye_guards", "relationship": "requires" },
    { "from": "copilot_agent", "to": "ast_mcp_server", "relationship": "queries" },
    { "from": "gemini_agent", "to": "ast_mcp_server", "relationship": "queries" },
    { "from": "ast_mcp_server", "to": "ast_engine", "relationship": "executes" },
    { "from": "copilot_agent", "to": "arch_docs", "relationship": "reads" },
    { "from": "gemini_agent", "to": "arch_docs", "relationship": "reads" },
    { "from": "copilot_agent", "to": "tech_inventory", "relationship": "reads" },
    { "from": "gemini_agent", "to": "tech_inventory", "relationship": "reads" },
    { "from": "arch_docs", "to": "ast_engine", "relationship": "sync_contract" }
  ],
  "runtimeContracts": [
    {
      "id": "shared_order_compatibility_surface",
      "path": "/v1/{orders,orders/{id},order/refunds}",
      "owner": "pegasus/apps/backend-go/orderroutes/routes.go",
      "delegatedFrom": "pegasus/apps/backend-go/main.go",
      "methods": [
        "GET /v1/orders",
        "GET /v1/orders/line-items/history",
        "GET /v1/order/refunds",
        "GET /v1/orders/{id}",
        "GET /v1/orders/{id}/events",
        "PATCH /v1/orders/{id}/status",
        "PATCH /v1/orders/{id}/state"
      ],
      "consumers": [
        "pegasus/apps/driverappios/driverappios/Services/APIClient.swift#getOrder",
        "pegasus/apps/driver-app-android/app/src/main/java/com/pegasus/driver/data/remote/DriverApi.kt#getOrder",
        "pegasus/apps/retailer-app-desktop/app/(dashboard)/orders/page.tsx selected-order fetch",
        "pegasus/apps/admin-portal/app/supplier/orders/page.tsx order detail drawer timeline fetch"
      ],
      "notes": [
        "GET returns an additive superset order-detail payload with line items.",
        "GET /v1/orders/{id}/events returns the scoped OrderEvents audit timeline for the same compatibility surface.",
        "PATCH accepts both /status and /state path aliases.",
        "PATCH accepts either status or state in the request body for legacy compatibility."
      ]
    },
