    {
      "name": "Legacy order detail compatibility surface",
      "path": "/v1/orders/{id}",
      "owner": "pegasus/apps/backend-go/order/legacy_orders.go",
      "delegatedFrom": "pegasus/apps/backend-go/main.go",
      "methods": [
        "GET /v1/orders/{id}",
        "GET /v1/orders/{id}/events",
        "PATCH /v1/orders/{id}/status",
        "PATCH /v1/orders/{id}/state"
      ],
      "consumers": [
        "driverappios APIClient.getOrder",
        "driver-app-android DriverApi.getOrder",
        "retailer-app-desktop selected order detail fetch",
        "admin-portal supplier order detail drawer event timeline"
      ],
      "notes": [
        "GET returns an additive superset order detail payload with line items.",
        "GET /v1/orders/{id}/events returns the scoped OrderEvents audit timeline for the same legacy order surface.",
        "PATCH accepts both /status and /state path aliases.",
        "PATCH accepts either status or state request keys for legacy compatibility."
      ]
    },
    {
      "name": "Supplier geo-planning surface",
      "path": "/v1/supplier/{serving-warehouse,geo-report,zone-preview,warehouses/validate-coverage,warehouse-loads}",
      "owner": "pegasus/apps/backend-go/proximityroutes/routes.go",
      "delegatedFrom": "pegasus/apps/backend-go/main.go",
      "methods": [
        "GET /v1/supplier/serving-warehouse",
        "GET /v1/supplier/geo-report",
        "GET /v1/supplier/zone-preview",
        "POST /v1/supplier/warehouses/validate-coverage",
        "GET /v1/supplier/warehouse-loads"
      ],
      "consumers": [
        "admin-portal supplier geo report page",
        "admin-portal supplier warehouse coverage editor",
        "admin-portal warehouse coverage map"
      ],
      "notes": [
        "Route composition moved out of main.go into proximityroutes without changing the delegated proximity handlers.",
        "The portal currently consumes geo-report, zone-preview, and validate-coverage; serving-warehouse and warehouse-loads remain supplier-facing backend planning support surfaces."
      ]
    },
    {
        "name": "Warehouse ops compatibility surface",
        "path": "/v1/warehouse/ops/*",
        "owner": "pegasus/apps/backend-go/warehouseroutes/routes.go",
        "methods": [
          "GET /v1/warehouse/ops/inventory",
          "PATCH /v1/warehouse/ops/inventory",
          "GET /v1/warehouse/ops/staff",
          "POST /v1/warehouse/ops/staff",
          "GET /v1/warehouse/ops/drivers",
          "POST /v1/warehouse/ops/drivers",
          "PATCH /v1/warehouse/ops/drivers/{id}/assign-vehicle",
          "GET /v1/warehouse/ops/vehicles",
          "POST /v1/warehouse/ops/vehicles",
          "PATCH /v1/warehouse/ops/vehicles/{id}",
          "GET /v1/warehouse/ops/vehicles/{id}"
        ],
        "consumers": [
          "warehouse-portal inventory/staff/drivers/vehicles pages",
          "warehouse-app-ios WarehouseService",
          "warehouse-app-android WarehouseApi"
        ],
        "notes": [
          "Inventory accepts q and search filters and accepts sku_id or product_id for mutations.",
          "Inventory responses expose both inventory and items collections plus sku_id and product_id aliases.",
          "Staff create accepts an optional pin and returns the effective one-time pin for native client parity.",
          "Vehicle responses expose both max_volume_vu and capacity_vu plus a derived availability status.",
          "Warehouse fleet controls now share driver assign/reset and vehicle activate/deactivate mutations across portal, iOS, and Android.",
          "Warehouse dispatch preview excludes inactive vehicles from the available-driver list so vehicle availability mutations affect dispatch eligibility immediately."
        ]
      },
      {
        "name": "Warehouse live websocket surface",
        "path": "/ws/warehouse",
        "owner": "pegasus/apps/backend-go/ws/warehouse_hub.go",
        "methods": [
          "WS /ws/warehouse"
        ],
        "consumers": [
          "warehouse-portal supply-requests and dispatch-lock pages",
          "warehouse-app-ios DispatchView",
          "warehouse-app-android DispatchScreen"
        ],
        "notes": [
          "Post-commit emitters live in warehouse/supply_requests.go and warehouse/dispatch_lock.go.",
          "Frames include warehouse_id and timestamp for cross-client filtering.",
          "Current live event types are SUPPLY_REQUEST_UPDATE and DISPATCH_LOCK_CHANGE.",
          "Portal, iOS, and Android clients auto-reconnect and surface reconnecting/offline live state instead of silently freezing."
        ]
      },
      {
        "name": "Warehouse dispatch mutation surface",
        "path": "/v1/warehouse/supply-requests + /v1/warehouse/dispatch-lock*",
        "owner": "pegasus/apps/backend-go/warehouse/supply_requests.go + pegasus/apps/backend-go/warehouse/dispatch_lock.go",
        "methods": [
          "POST /v1/warehouse/supply-requests",
          "PATCH /v1/warehouse/supply-requests/{id}",
          "GET /v1/warehouse/dispatch-locks",
          "POST /v1/warehouse/dispatch-lock",
          "DELETE /v1/warehouse/dispatch-lock?lock_id={id}"
        ],
        "consumers": [
          "warehouse-portal supply-request detail and dispatch-lock pages",
          "warehouse-app-ios DispatchView + WarehouseService",
          "warehouse-app-android DispatchScreen + WarehouseApi"
        ],
        "notes": [
          "Create flow submits demand-forecast-backed warehouse supply requests from dispatch surfaces.",
          "Warehouse clients can cancel supply requests in warehouse-owned states and acquire or release MANUAL_DISPATCH locks through the same contract.",
          "Dispatch control parity now spans portal, iOS, and Android warehouse clients."
        ]
    }
