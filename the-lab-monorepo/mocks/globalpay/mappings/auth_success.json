{
  "priority": 5,
  "request": {
    "method": "POST",
    "urlPathPattern": ".*/merchant/auth.*",
    "bodyPatterns": [
      { "matchesJsonPath": "$.username" }
    ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "access_token": "MOCK_TOKEN_{{randomValue type='UUID'}}",
      "token_type": "Bearer",
      "expires_in": 3600,
      "isSuccessful": true
    }
  }
}
