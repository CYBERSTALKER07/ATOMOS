{
  "priority": 5,
  "request": {
    "method": "POST",
    "urlPathPattern": ".*/payments/v2/payment/.+/perform$"
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "paymentId": "{{request.pathSegments.[3]}}",
      "status": "SUCCESS",
      "paid": true,
      "isSuccessful": true
    }
  }
}
