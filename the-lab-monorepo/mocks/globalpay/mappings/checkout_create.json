{
  "priority": 5,
  "request": {
    "method": "POST",
    "urlPathPattern": ".*/user-service-tokens.*",
    "bodyPatterns": [
      { "matchesJsonPath": "$.serviceId" }
    ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "userRedirectUrl": "http://localhost:8082/simulate/checkout/{{randomValue type='UUID'}}",
      "userServiceToken": "MOCK_UST_{{randomValue type='UUID'}}",
      "paymentId": "MOCK_PAY_{{randomValue type='UUID'}}",
      "isSuccessful": true
    }
  }
}
