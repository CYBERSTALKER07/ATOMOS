{
  "priority": 10,
  "request": {
    "method": "POST",
    "urlPathPattern": ".*/payments/v2/payment/init$",
    "bodyPatterns": [
      { "matchesJsonPath": "$.recipients[?(@.amount < 0)]" }
    ]
  },
  "response": {
    "status": 400,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "error": "INVALID_SPLIT_AMOUNT",
      "message": "Split recipient amounts cannot be negative."
    }
  }
}
