{
  "priority": 10,
  "request": {
    "method": "POST",
    "urlPathPattern": ".*/payments/v2/payment/init$",
    "bodyPatterns": [
      { "contains": "CHAOS_3DS" }
    ]
  },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "jsonBody": {
      "paymentId": "MOCK_3DS_{{randomValue type='UUID'}}",
      "status": "REQUIRES_3DS",
      "securityCheckUrl": "http://localhost:8082/simulate/3ds/{{randomValue type='UUID'}}",
      "isSuccessful": true
    }
  }
}
