{
  "batch": "Batch 02A - Driver Mobile Surfaces",
  "algorithms": [
    {
      "name": "h3_dispatch_driver_override_guard",
      "nodes": [
        "telemetry_ingest",
        "h3_resolution",
        "candidate_cluster",
        "freeze_lock_check",
        "optimizer_sequence",
        "manual_override_scope",
        "outbox_emit",
        "ws_broadcast"
      ],
      "transitions": [
        "telemetry_ingest->h3_resolution",
        "h3_resolution->candidate_cluster",
        "candidate_cluster->freeze_lock_check",
        "freeze_lock_check->optimizer_sequence",
        "optimizer_sequence->manual_override_scope",
        "manual_override_scope->outbox_emit",
        "outbox_emit->ws_broadcast"
      ],
      "guard_conditions": [
        "freeze_lock_required_for_human_mutation",
        "manual_override_constrained_to_active_task_scope",
        "aggregate_id_partition_key_for_event_order"
      ],
      "recovery_paths": [
        "if_lock_active_hold_current_assignment",
        "if_ws_fanout_fails_continue_local_delivery"
      ]
    },
    {
      "name": "freeze_lock_human_ai_cooperation",
      "nodes": [
        "mutation_request",
        "lock_acquire",
        "lock_persist",
        "lock_event_emit",
        "ai_queue_drop",
        "human_adjustment_window",
        "lock_release",
        "ai_reenqueue"
      ],
      "transitions": [
        "mutation_request->lock_acquire",
        "lock_acquire->lock_persist",
        "lock_persist->lock_event_emit",
        "lock_event_emit->ai_queue_drop",
        "ai_queue_drop->human_adjustment_window",
        "human_adjustment_window->lock_release",
        "lock_release->ai_reenqueue"
      ],
      "guard_conditions": [
        "lock_ttl_enforced",
        "manual_edits_disallow_ai_override_during_lock",
        "release_event_restores_optimizer_control"
      ],
      "recovery_paths": [
        "if_release_missing_auto_release_after_ttl",
        "if_consumer_lag_exceeds_threshold_raise_alert"
      ]
    },
    {
      "name": "idempotent_completion_outbox_atomicity",
      "nodes": [
        "completion_submit",
        "idempotency_lookup",
        "rw_transaction_begin",
        "geofence_validation",
        "order_ledger_mutation",
        "outbox_write",
        "commit",
        "cache_invalidate",
        "relay_publish"
      ],
      "transitions": [
        "completion_submit->idempotency_lookup",
        "idempotency_lookup->rw_transaction_begin",
        "rw_transaction_begin->geofence_validation",
        "geofence_validation->order_ledger_mutation",
        "order_ledger_mutation->outbox_write",
        "outbox_write->commit",
        "commit->cache_invalidate",
        "cache_invalidate->relay_publish"
      ],
      "guard_conditions": [
        "same_idempotency_key_replays_original_response",
        "completion_requires_geofence_pass",
        "order_and_outbox_atomic_in_same_transaction"
      ],
      "recovery_paths": [
        "if_duplicate_key_return_saved_payload",
        "if_commit_fails_no_event_emitted"
      ]
    },
    {
      "name": "predictive_preorder_driver_readiness",
      "nodes": [
        "history_ingest",
        "feature_windowing",
        "demand_inference",
        "preload_recommendation",
        "capacity_policy_check",
        "driver_visibility",
        "driver_acceptance",
        "manifest_attach"
      ],
      "transitions": [
        "history_ingest->feature_windowing",
        "feature_windowing->demand_inference",
        "demand_inference->preload_recommendation",
        "preload_recommendation->capacity_policy_check",
        "capacity_policy_check->driver_visibility",
        "driver_visibility->driver_acceptance",
        "driver_acceptance->manifest_attach"
      ],
      "guard_conditions": [
        "recommendation_is_advisory_not_mandatory",
        "capacity_and_policy_gate_before_commit",
        "legacy_clients_ignore_new_recommendation_fields"
      ],
      "recovery_paths": [
        "if_inference_unavailable_fallback_to_baseline_route",
        "if_driver_declines_preserve_existing_manifest"
      ]
    }
  ]
}
