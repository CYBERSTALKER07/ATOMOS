# Copy to `.env` and edit. Expo reads EXPO_PUBLIC_* at bundle time.
# Simulator only: leave unset — App.tsx falls back to http://localhost:8080.
# Physical device: set to the Mac's LAN IP so the Expo bundle on the phone
# can reach the backend over Wi-Fi, e.g. http://192.168.1.42:8080.
EXPO_PUBLIC_API_URL=http://localhost:8080
